# ---------------------------------------------------------------------------
# Google Maps API credentials
# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in your real key. NEVER commit the real
# ".env" file to version control (it is already listed in .gitignore).
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ---------------------------------------------------------------------------
# Search configuration (optional overrides — sensible defaults are set in
# src/config.py if these are omitted)
# ---------------------------------------------------------------------------
# Center point of Ranchi main city area
SEARCH_LAT=23.3441
SEARCH_LNG=85.3096

# Search radius in meters (max allowed by Nearby Search is 50000)
SEARCH_RADIUS_METERS=12000

# Seconds to wait between paginated requests (Google requires a short delay
# before a next_page_token becomes valid — do not set below 2)
PAGE_TOKEN_DELAY_SECONDS=2

# Output directory overrides (optional)
DATA_DIR=data
MAPS_DIR=maps
